def test_create_vector_store_valid():
    """
    Test whether create_vector_store() creates a vector database successfully.
 
    This test creates a real temporary Chroma DB folder.
    On Windows, Chroma may lock some files temporarily.
    So cleanup is handled using safe_delete_folder().
    """
 
    print("\ntest_create_vector_store_valid")
 
    # Create temporary folder for documents
    temp_docs_dir = create_sample_docs()
 
    # Create temporary folder for vector database
    temp_db_dir = tempfile.mkdtemp()
 
    # Store vectorstore reference here so it can be cleared in finally block
    actual_output = None
 
    try:
        # Load documents from temporary docs folder
        documents = run_without_internal_prints(load_documents, temp_docs_dir)
 
        # Split loaded documents into chunks
        chunks = run_without_internal_prints(split_documents, documents)
 
        # Expected result
        expected_output = "valid vector store object"
 
        # Create vector database using chunks
        actual_output = run_without_internal_prints(
            create_vector_store,
            chunks,
            temp_db_dir
        )
 
        # Print expected and actual output
        print(f"Expected Output: {expected_output}")
        print(f"Actual Output  : {type(actual_output).__name__}")
 
        # Vector store should not be None
        assert actual_output is not None
 
        # Chroma vector store should have get() method
        assert hasattr(actual_output, "get")
 
    finally:
        # Remove reference to vectorstore object
        # This helps release Chroma file handles
        actual_output = None
 
        # Force garbage collection before deleting folders
        gc.collect()
 
        # Delete temporary document folder safely
        safe_delete_folder(temp_docs_dir)
 
        # Delete temporary database folder safely
        safe_delete_folder(temp_db_dir)
 
 
