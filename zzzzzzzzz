    1. Create a temporary folder.
    2. Create a sample.pdf file inside that folder.
    3. Return the temporary folder path.
 
    This is used to test whether load_documents() raises ValueError
    when the folder exists but does not contain any .txt files.
    """
 
    # Create a temporary folder
    temp_dir = tempfile.mkdtemp()
 
    # Create a non-text file inside the temporary folder
    file_path = os.path.join(temp_dir, "sample.pdf")
 
    # Write sample content into the non-text file
    with open(file_path, "w", encoding="utf-8") as file:
        file.write("This is not a text file.")
 
    # Return temporary folder path
    return temp_dir
 
 
