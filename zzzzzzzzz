# =========================================================
 
def create_sample_docs():
    """
    This function creates a temporary folder with one .txt file.
 
    Flow:
    1. Create a temporary folder.
    2. Create a sample.txt file inside that folder.
    3. Write sample text into the file.
    4. Return the temporary folder path.
 
    This is used for valid test cases because load_documents()
    needs a real folder containing .txt files.
    """
 
    # Create a temporary folder
    temp_dir = tempfile.mkdtemp()
 
    # Create a sample text file path inside the temporary folder
    file_path = os.path.join(temp_dir, "sample.txt")
 
    # Write sample content into the .txt file
    with open(file_path, "w", encoding="utf-8") as file:
        file.write("Sample document for testing ingestion pipeline.")
 
    # Return temporary folder path
    return temp_dir
 
 
def create_folder_without_txt_file():
    """
    This function creates a temporary folder with a non-text file.
 
