# =========================================================
 
class FakeVectorStore:
    """
    This fake class is used instead of real Chroma DB.
 
    In the real retrieval pipeline, vectorstore.get() returns a dictionary:
    {
        "documents": ["doc1", "doc2"]
    }
 
    This fake class returns the same structure for testing.
    """
 
    def __init__(self, documents):
        # Store test documents
        self.documents = documents
 
    def get(self):
        # Return documents in the same format as Chroma vectorstore
        return {"documents": self.documents}
 
 
class FakeVectorStoreWithoutGet:
    """
    This fake class does not contain get() method.
 
    This is used to check whether retrieve_documents()
    raises TypeError when vectorstore does not have get().
    """
 
    pass
 
 
class FakeVectorStoreInvalidReturn:
    """
    This fake class contains get() method,
    but get() returns a list instead of dictionary.
 
    This is used to check whether retrieve_documents()
    raises TypeError when vectorstore.get() returns invalid data type.
    """
 
    def get(self):
        return ["invalid data"]
 
 
class FakeVectorStoreWithoutDocumentsKey:
    """
    This fake class returns a dictionary,
    but the dictionary does not contain the required 'documents' key.
 
    This is used to check whether retrieve_documents()
    raises KeyError when 'documents' key is missing.
    """
 
    def get(self):
        return {"data": ["document one"]}
 
 
