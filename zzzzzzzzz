def test_retrieve_documents_valid():
    """
    Test whether retrieve_documents() returns top matching documents.
 
    Flow:
    1. Create sample documents.
    2. Store those documents in FakeVectorStore.
    3. Create LocalEmbeddings object.
    4. Call retrieve_documents() with a valid query.
    5. Check whether top 2 results are returned.
    """
 
    print("\n" + "=" * 80)
    print("VALID TEST CASES")
    print("=" * 80)
 
    print("\ntest_retrieve_documents_valid")
 
    # Sample documents stored inside fake vectorstore
    docs = [
        "RAG means Retrieval Augmented Generation",
        "Vector database stores embeddings",
        "TF IDF converts text into vectors"
    ]
 
    # Create fake vectorstore with sample documents
    vectorstore = FakeVectorStore(docs)
 
    # Create LocalEmbeddings object
    embeddings = LocalEmbeddings()
 
    # Expected output description
    expected_output = "list containing top 2 retrieved documents"
 
    # Call retrieve_documents() while hiding internal print statements
    actual_output = run_without_internal_prints(
        retrieve_documents,
        "What is RAG",
        vectorstore,
        embeddings,
        2
    )
 
    # Print expected and actual output
    print(f"Expected Output: {expected_output}")
    print(f"Actual Output  : {type(actual_output).__name__}")
 
    # Output should be a list
    assert isinstance(actual_output, list)
 
    # Since k is 2, output should contain exactly 2 results
    assert len(actual_output) == 2
 
    # Each result should be a tuple in the format: (score, document)
    for result in actual_output:
        assert isinstance(result, tuple)
        assert len(result) == 2
 
        # First value should be similarity score
        assert isinstance(result[0], float)
 
        # Second value should be document text
        assert isinstance(result[1], str)
 
 
