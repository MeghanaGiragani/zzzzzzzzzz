# =========================================================
# UNIT TESTS FOR ingestion_pipeline.py
# =========================================================
 
# os is used for file and folder path operations
import os
 
# sys is used to add project root path for importing files
import sys
 
# shutil is used to delete temporary folders after testing
import shutil
 
# tempfile is used to create temporary folders for testing
import tempfile
 
# pytest is used for writing and running test cases
import pytest
 
# io and redirect_stdout are used to hide internal print statements
# from ingestion_pipeline.py during testing
import io
from contextlib import redirect_stdout
 
# gc is used to force garbage collection.
# This helps release Chroma DB file handles before deleting temporary folders.
import gc
 
 
# =========================================================
# ADD PROJECT ROOT PATH
# =========================================================
 
# This allows this test file to import ingestion_pipeline.py
# from the main project folder.
sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
 
 
# =========================================================
# IMPORT FUNCTIONS FROM ingestion_pipeline.py
# =========================================================
 
from ingestion_pipeline import (
    load_documents,
    split_documents,
    LocalEmbeddings,
    create_vector_store
)
 
 
# =========================================================
# HELPER FUNCTION TO HIDE INTERNAL PRINTS
# =========================================================
 
def run_without_internal_prints(function, *args, **kwargs):
    """
    This helper function runs any function while hiding print statements
    written inside ingestion_pipeline.py.
 
    Reason:
    ingestion_pipeline.py already prints internal messages.
    During unit testing, we only want to display:
    test name, expected output, and actual output.
    """
 
    # Create a temporary string buffer to capture internal print output
    hidden_output = io.StringIO()
 
    # Redirect all print statements from the called function into hidden_output
    with redirect_stdout(hidden_output):
        return function(*args, **kwargs)
 
 
# =========================================================
# HELPER FUNCTION TO SAFELY DELETE TEMPORARY FOLDERS
# =========================================================
 
def safe_delete_folder(folder_path):
    """
    Safely deletes a folder during testing.
 
    Reason:
    Chroma DB can keep some files open for a short time on Windows.
    If shutil.rmtree() tries to delete those locked files immediately,
    Windows may raise PermissionError.
 
    This helper prevents cleanup errors from failing the test.
    """
 
    # Force Python to clean unused objects and release file references
    gc.collect()
 
    # Delete folder only if it exists
    if os.path.exists(folder_path):
        shutil.rmtree(folder_path, ignore_errors=True)
 
 
